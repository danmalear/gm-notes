{
	"name": "gm-notes-server",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"lint": "eslint .",
		"type-check": "tsc -p tsconfig.json",
		"test": "node --test --watch"
	},
	"imports": {
		"#ability-check/*": "./src/ability-check/*",
		"#action/*": "./src/action/*",
		"#campaign/*": "./src/campaign/*",
		"#command/*": "./src/framework/command/*",
		"#condition/*": "./src/condition/*",
		"#event/*": "./src/framework/event/*",
		"#file/*": "./src/file/*",
		"#framework/*": "./src/framework/*",
		"#handout/*": "./src/handout/*",
		"#item/*": "./src/item/*",
		"#map/*": "./src/map/*",
		"#message/*": "./src/framework/message/*",
		"#narration/*": "./src/narration/*",
		"#note/*": "./src/note/*",
		"#prisma/*": "./prisma/*",
		"#prisma-client": "./prisma/generated/client.ts",
		"#prisma-enums": "./prisma/generated/enums.ts",
		"#prisma-models/*": "./prisma/generated/models/*",
		"#region/*": "./src/region/*",
		"#shared/*": "./src/shared/*",
		"#stream/*": "./src/framework/stream/*"
	},
	"dependencies": {
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"cors": "2.8.6",
		"dotenv": "17.4.0",
		"express": "5.2.1",
		"knex": "3.2.8",
		"lodash": "4.18.1",
		"multer": "2.1.1",
		"pg": "8.20.0",
		"prisma": "^7.8.0",
		"ws": "8.20.0"
	},
	"devDependencies": {
		"@eslint/js": "9.39.4",
		"@types/cors": "2.8.19",
		"@types/express": "5.0.6",
		"@types/lodash": "4.17.24",
		"@types/multer": "1.4.13",
		"@types/node": "22.19.15",
		"@types/ws": "8.18.1",
		"eslint": "9.39.4",
		"eslint-config-prettier": "10.1.8",
		"globals": "16.5.0",
		"prettier": "3.5.3",
		"typescript": "5.7.3",
		"typescript-eslint": "8.58.0"
	}
}
