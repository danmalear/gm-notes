generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider     = "postgresql"
  relationMode = "prisma"
  schemas      = ["public", "es"]
}

model AbilityCheck {
  AbilityCheckId             String     @id @db.Uuid
  ActionId                   String     @db.Uuid
  Action                     Action     @relation(fields: [ActionId], references: [ActionId])
  Skill                      Skill
  DC                         Int
  SuccessNarrationId         String?    @db.Uuid
  SuccessNarration           Narration? @relation(name: "Success", fields: [SuccessNarrationId], references: [NarrationId])
  FailureNarrationId         String?    @db.Uuid
  FailureNarration           Narration? @relation(name: "Failure", fields: [FailureNarrationId], references: [NarrationId])
  CriticalSuccessNarrationId String?    @db.Uuid
  CriticalSuccessNarration   Narration? @relation(name: "CriticalSuccess", fields: [CriticalSuccessNarrationId], references: [NarrationId])
  CriticalFailureNarrationId String?    @db.Uuid
  CriticalFailureNarration   Narration? @relation(name: "CriticalFailure", fields: [CriticalFailureNarrationId], references: [NarrationId])

  @@index([SuccessNarrationId])
  @@index([FailureNarrationId])
  @@index([CriticalSuccessNarrationId])
  @@index([CriticalFailureNarrationId])
  @@index([ActionId])
  @@schema("public")
}

model Action {
  ActionId         String            @id @db.Uuid
  TargetId         String            @db.Uuid
  Region           Region?           @relation(name: "TargetRegion", fields: [TargetId], references: [RegionId], map: "Action_RegionId_fkey")
  Item             Item?             @relation(name: "TargetItem", fields: [TargetId], references: [ItemId], map: "Action_ItemId_fkey")
  LocationItem     LocationItem?     @relation(name: "TargetLocationItem", fields: [TargetId], references: [LocationItemId], map: "Action_LocationItemId_fkey")
  Name             String
  Type             ActionType?
  NarrationId      String?           @db.Uuid
  Narration        Narration?        @relation(fields: [NarrationId], references: [NarrationId])
  AbilityChecks    AbilityCheck[]
  ActionConditions ActionCondition[]

  @@index([NarrationId])
  @@index([TargetId])
  @@schema("public")
}

model ActionCondition {
  ActionId    String    @db.Uuid
  Action      Action    @relation(fields: [ActionId], references: [ActionId])
  ConditionId String    @db.Uuid
  Condition   Condition @relation(fields: [ConditionId], references: [ConditionId])

  @@id([ActionId, ConditionId])
  @@index([ConditionId])
  @@schema("public")
}

enum ActionType {
  Attack
  Dash
  Disengage
  Dodge
  Help
  Hide
  Influence
  Magic
  Ready
  Search
  Study
  Utilize

  @@schema("public")
}

model Campaign {
  CampaignId         String      @id @db.Uuid
  CampaignTemplateId String?     @db.Uuid
  Name               String
  ActiveMapId        String?     @db.Uuid
  ActiveMap          Map?        @relation(name: "CampaignActiveMap", fields: [ActiveMapId], references: [MapId])
  Conditions         Condition[]
  Handouts           Handout[]
  Items              Item[]
  Maps               Map[]       @relation(name: "MapCampaign")

  @@index([ActiveMapId])
  @@schema("public")
}

model CampaignTemplate {
  CampaignTemplateId String @id @db.Uuid
  Name               String @db.VarChar(63)

  @@schema("public")
}

model Condition {
  ConditionId      String            @id @db.Uuid
  Name             String
  Description      String
  IsMet            Boolean           @default(false)
  CampaignId       String            @db.Uuid
  Campaign         Campaign          @relation(fields: [CampaignId], references: [CampaignId])
  ActionConditions ActionCondition[]

  @@index([CampaignId])
  @@schema("public")
}

enum CurrencyUnit {
  CP
  SP
  EP
  GP
  PP

  @@schema("public")
}

model File {
  FileId   String @id @db.Uuid
  FileName String
  Item     Item?
  Map      Map?

  @@schema("public")
}

model Handout {
  HandoutId      String          @id @db.Uuid
  CampaignId     String          @db.Uuid
  Campaign       Campaign        @relation(fields: [CampaignId], references: [CampaignId])
  Name           String
  Type           HandoutType
  Source         String
  RegionHandouts RegionHandout[]

  @@index([CampaignId])
  @@schema("public")
}

enum HandoutType {
  Text
  Image
  File

  @@schema("public")
}

model Item {
  ItemId        String         @id @db.Uuid
  CampaignId    String?        @db.Uuid
  Campaign      Campaign?      @relation(fields: [CampaignId], references: [CampaignId])
  Name          String
  IsContainer   Boolean        @default(false)
  Value         Int?
  ValueUnit     CurrencyUnit?
  DetailsLink   String?
  ImageFileId   String?        @unique
  ImageFile     File?          @relation(fields: [ImageFileId], references: [FileId])
  Actions       Action[]       @relation(name: "TargetItem")
  LocationItems LocationItem[]
  Notes         Note[]         @relation(name: "ParentItem")

  @@index([CampaignId])
  @@schema("public")
}

model LocationItem {
  LocationItemId String         @id @db.Uuid
  LocationId     String         @db.Uuid
  Region         Region?        @relation(name: "RegionItem", fields: [LocationId], references: [RegionId], map: "LocationItem_RegionId_fkey")
  Container      LocationItem?  @relation(name: "ContainerContents", fields: [LocationId], references: [LocationItemId], onUpdate: Restrict, map: "LocationItem_ContainerId_fkey")
  ItemId         String         @db.Uuid
  Item           Item           @relation(fields: [ItemId], references: [ItemId])
  Quantity       Int            @default(1)
  Actions        Action[]       @relation(name: "TargetLocationItem")
  Notes          Note[]         @relation(name: "ParentLocationItem")
  Contents       LocationItem[] @relation(name: "ContainerContents")

  @@index([LocationId])
  @@index([ItemId])
  @@schema("public")
}

model Map {
  MapId           String     @id @db.Uuid
  CampaignId      String     @db.Uuid
  Campaign        Campaign   @relation(name: "MapCampaign", fields: [CampaignId], references: [CampaignId], onUpdate: Restrict)
  MapTemplateId   String?    @db.Uuid
  Name            String
  ImageFileId     String     @unique
  ImageFile       File       @relation(fields: [ImageFileId], references: [FileId])
  DefaultLighting String     @default("Bright Light")
  Width           Int        @default(0)
  Height          Int        @default(0)
  Campaigns       Campaign[] @relation(name: "CampaignActiveMap")

  @@index([CampaignId])
  @@schema("public")
}

model MapTemplate {
  MapTemplateId      String  @id @db.Uuid
  CampaignTemplateId String? @db.Uuid
  Name               String  @db.VarChar(63)
  ImagePath          String  @db.VarChar(255)

  @@schema("public")
}

model Narration {
  NarrationId                  String            @id @db.Uuid
  NarrationTemplateId          String?           @db.Uuid
  Name                         String
  Description                  String
  IsRead                       Boolean           @default(false)
  Actions                      Action[]
  RegionNarrations             RegionNarration[]
  SuccessAbilityChecks         AbilityCheck[]    @relation(name: "Success")
  FailureAbilityChecks         AbilityCheck[]    @relation(name: "Failure")
  CriticalSuccessAbilityChecks AbilityCheck[]    @relation(name: "CriticalSuccess")
  CriticalFailureAbilityChecks AbilityCheck[]    @relation(name: "CriticalFailure")

  @@schema("public")
}

model NarrationTemplate {
  NarrationTemplateId String @id @db.Uuid
  Name                String @db.VarChar(255)
  Description         String @db.VarChar(255)

  @@schema("public")
}

model Note {
  NoteId       String        @id @db.Uuid
  EntityId     String        @db.Uuid
  Region       Region?       @relation(name: "ParentRegion", fields: [EntityId], references: [RegionId], map: "Note_RegionId_fkey")
  Item         Item?         @relation(name: "ParentItem", fields: [EntityId], references: [ItemId], map: "Note_ItemId_fkey")
  LocationItem LocationItem? @relation(name: "ParentLocationItem", fields: [EntityId], references: [LocationItemId], map: "Note_LocationItemId_fkey")
  Description  String

  @@index([EntityId])
  @@schema("public")
}

model Region {
  RegionId         String            @id @db.Uuid
  RegionTemplateId String?           @db.Uuid
  MapId            String            @db.Uuid
  Name             String
  Lighting         String            @default("Default")
  Actions          Action[]          @relation(name: "TargetRegion")
  Items            LocationItem[]    @relation(name: "RegionItem")
  Notes            Note[]            @relation(name: "ParentRegion")
  Handouts         RegionHandout[]
  Narrations       RegionNarration[]
  Shapes           RegionShape[]

  @@schema("public")
}

model RegionHandout {
  RegionId  String  @db.Uuid
  Region    Region  @relation(fields: [RegionId], references: [RegionId])
  HandoutId String  @db.Uuid
  Handout   Handout @relation(fields: [HandoutId], references: [HandoutId])

  @@id([RegionId, HandoutId])
  @@index([HandoutId])
  @@schema("public")
}

model RegionNarration {
  RegionId    String    @db.Uuid
  Region      Region    @relation(fields: [RegionId], references: [RegionId])
  NarrationId String    @db.Uuid
  Narration   Narration @relation(fields: [NarrationId], references: [NarrationId])

  @@id([RegionId, NarrationId])
  @@index([NarrationId])
  @@schema("public")
}

model RegionShape {
  RegionShapeId String    @id @db.Uuid
  RegionId      String    @db.Uuid
  Region        Region    @relation(fields: [RegionId], references: [RegionId])
  ShapeType     ShapeType
  Coords        Json

  @@index([RegionId])
  @@schema("public")
}

model RegionTemplate {
  RegionTemplateId String @id @db.Uuid
  MapTemplateId    String @db.Uuid
  Name             String @db.VarChar(63)

  @@schema("public")
}

enum ShapeType {
  Circle
  Polygon
  Rectangle

  @@schema("public")
}

enum Skill {
  Acrobatics
  AnimalHandling @map("Animal Handling")
  Arcana
  Athletics
  Deception
  History
  Insight
  Intimidation
  Investigation
  Medicine
  Nature
  Perception
  Performance
  Persuasion
  Religion
  SleightOfHand  @map("Sleight of Hand")
  Stealth
  Survival

  @@schema("public")
}
