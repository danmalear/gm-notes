{
	"name": "map-data-frontend",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"lint": "eslint .",
		"preview": "vite preview",
		"type-check": "tsc -p tsconfig.app.json"
	},
	"imports": {
		"#ability-check/*": "./src/ability-check/*",
