{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "vite",
			"type": "shell",
			"command": "pnpm run dev",
			"options": {
				"cwd": "frontend"
			},
			"isBackground": true,
			"problemMatcher": {
				"pattern": {
					"regexp": "."
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "VITE v",
					"endsPattern": "ready in .*ms"
				}
			},
			"hide": false,
			"detail": "Start the Vite dev server"
		},
		{
			"label": "node",
			"type": "shell",
			"command": "node --watch src/server.ts",
			"options": {
				"cwd": "backend"
			},
			"problemMatcher": {
				"pattern": {
					"regexp": "."
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "Server listening on port",
					"endsPattern": "Server listening on port"
				}
			},
			"isBackground": true,
			"hide": false,
			"detail": "Start the backend Node server"
		},
		{
			"label": "start-all",
			"dependsOn": ["node", "vite"],
			"dependsOrder": "sequence"
		},
		{
			"label": "stop-all",
			"type": "shell",
			"command": "echo ${input:terminate}"
		}
	],
	"inputs": [
		{
			"id": "terminate",
			"type": "command",
			"command": "workbench.action.tasks.terminate",
			"args": "terminateAll"
		}
	]
}
